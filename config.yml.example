Log:
  Level: info
  Output: /var/log/v2naive/v2naive.log

Runtime:
  Engine: caddy
  CaddyPath: /opt/v2naive/caddy
  WorkingDir: /var/lib/v2naive
  AdminPortBase: 22019

Nodes:
  - ApiHost: "https://your-panel.example.com"
    NodeID: 1
    ApiKey: "your-server-token"
    Timeout: 15
    RetryCount: 2
